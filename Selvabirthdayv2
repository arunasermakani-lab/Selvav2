<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>For Selva ❤️</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

body{
font-family:'Segoe UI',sans-serif;
background:#fff5f8;
overflow-x:hidden;
text-align:center;
}

/* FLOATING HEARTS */

.heart{
position:fixed;
bottom:-50px;
font-size:24px;
animation:floatHeart linear infinite;
opacity:.7;
z-index:1;
}

@keyframes floatHeart{
0%{
transform:translateY(0);
opacity:0;
}
20%{
opacity:1;
}
100%{
transform:translateY(-120vh);
opacity:0;
}
}

/* COUNTDOWN PAGE */

#countdownPage{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
padding:20px;
}

#countdownPage h1{
font-size:2.3rem;
color:#d86b8f;
}

#countdown{
font-size:2rem;
margin-top:20px;
color:#ff5c8d;
font-weight:bold;
}

/* UNLOCK PAGE */

#unlockPage{
display:none;
height:100vh;
justify-content:center;
align-items:center;
flex-direction:column;
}

.sparkle{
position:absolute;
font-size:24px;
animation:sparkle 3s infinite;
}

@keyframes sparkle{
0%{
opacity:0;
}
50%{
opacity:1;
}
100%{
opacity:0;
}
}

button{
padding:14px 30px;
border:none;
border-radius:30px;
background:#ff6f9d;
color:white;
font-size:18px;
cursor:pointer;
margin-top:20px;
}

/* SCRAPBOOK */

#birthdayPage{
display:none;
padding:30px 15px;
background:#fffafc;
}

.birthdayTitle{
color:#d86b8f;
margin-bottom:30px;
}

.photoCard{
max-width:400px;
margin:30px auto;
background:white;
padding:10px;
border-radius:20px;
box-shadow:0 5px 20px rgba(0,0,0,.15);
}

.photoCard img{
width:100%;
border-radius:15px;
}

.messageBlock{
background:white;
padding:20px;
max-width:700px;
margin:20px auto;
border-radius:20px;
font-size:20px;
line-height:1.8;
box-shadow:0 5px 20px rgba(0,0,0,.08);
}

.continueBtn{
margin:40px;
}
/* SUNSET PAGE */

.sunsetPage{
display:none;
height:100vh;
position:relative;
overflow:hidden;
background:black;
}

.sunsetPhoto{
width:100%;
height:100%;
object-fit:cover;
}

#sunsetText{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
width:90%;
color:white;
font-size:24px;
text-shadow:0 0 10px black;
}

.line{
opacity:0;
animation:fadeText 3s forwards;
}

.line2{
animation-delay:4s;
}

.line3{
animation-delay:8s;
}

@keyframes fadeText{
from{
opacity:0;
transform:translateY(20px);
}
to{
opacity:1;
transform:translateY(0);
}
}

.secretBtn{
display:none;
margin-top:30px;
}

/* SECRET PAGE */

.secretPage{
display:none;
padding:40px 20px;
background:#fff8f1;
min-height:100vh;
}

.letter{
max-width:700px;
margin:auto;
background:white;
padding:30px;
border-radius:25px;
box-shadow:0 5px 20px rgba(0,0,0,.15);
}

#typewriter{
font-size:20px;
line-height:2;
}

/* ENDING PAGE */

.endingPage{
display:none;
background:black;
color:white;
height:100vh;
justify-content:center;
align-items:center;
flex-direction:column;
}

.glowHeart{
font-size:100px;
animation:pulse 2s infinite;
}

@keyframes pulse{
0%{transform:scale(1);}
50%{transform:scale(1.2);}
100%{transform:scale(1);}
}

.confetti{
position:fixed;
top:-30px;
font-size:22px;
animation:fall 8s linear;
}

@keyframes fall{
from{
transform:translateY(-10vh);
}
to{
transform:translateY(110vh);
}
}

@keyframes petalFall{
from{
transform:translateY(-10vh);
}
to{
transform:translateY(110vh) translateX(100px);
}
}

</style>
</head>

<body>

<div id="countdownPage">
<h1>❤️ A Little Surprise Awaits ❤️</h1>
<p>26 June 2026</p>
<div id="countdown"></div>
</div>

<div id="unlockPage">
<div class="sparkle" style="top:20%;left:20%;">✨</div>
<div class="sparkle" style="top:30%;right:20%;">✨</div>
<div class="sparkle" style="top:70%;left:20%;">✨</div>
<div class="sparkle" style="top:60%;right:20%;">✨</div>

<h2>Someone has something to tell you ❤️</h2>

<button onclick="openBirthday()">
🎂 Open Your Birthday Surprise
</button>
</div>

<div id="birthdayPage">

<h1 class="birthdayTitle">
🎂 Happy Birthday Selva ❤️
</h1>

<div class="photoCard">
<img src="photo1.jpg">
</div>

<div class="messageBlock">
May that beautiful smile that I've always admired so much stay with you forever 😄
</div>

<div class="photoCard">
<img src="photo2.jpg">
</div>

<div class="messageBlock">
I hope every single day of your life is filled with moments that bring you happiness ☺️
</div>

<div class="photoCard">
<img src="photo3.jpg">
</div>

<div class="messageBlock">
I want to see you grow higher and higher in your career and achieve everything you've ever wished for 😇
</div>

<div class="photoCard">
<img src="photo4.jpg">
</div>

<div class="messageBlock">
I hope you get to visit all the places you've dreamed of and experience all the wonderful things life has to offer ✨
</div>

<div class="photoCard">
<img src="photo5.jpg">
</div>

<div class="messageBlock">
No matter where life takes us, I'll always be there to support you 🤝
</div>

<div class="photoCard">
<img src="photo6.jpg">
</div>

<div class="messageBlock">
It makes me a little sad that I can't be there with you on your special day to annoy and torture you in person 😅
<br><br>
But I hope one day I'll make up for it and create memories you'll cherish forever 🤗❤️
</div>

<button class="continueBtn" onclick="showSunset()">
🌅 Continue
</button>

</div>
<div id="sunsetPage" class="sunsetPage">

<img src="photo6.jpg" class="sunsetPhoto">

<div id="sunsetText">

<p class="line">
Some people become important without us realizing when it happened ☺️
</p>

<br>

<p class="line line2">
And somehow, they stay there 😇
</p>

<br>

<p class="line line3">
Just by being themselves ❤️
</p>

<button class="secretBtn" onclick="openSecret()">
💌 Just For You
</button>

</div>

</div>

<div id="secretPage" class="secretPage">

<div class="letter">

<h2>💌 Just For You</h2>

<br>

<div id="typewriter"></div>

<br>

<button onclick="showEnding()">
❤️
</button>

</div>

</div>

<div id="endingPage" class="endingPage">

<div class="glowHeart">❤️</div>

<h1>Iniya Pirandha Naal Vaazhthukkal ❤️</h1>

<h2>Thangapulla 🥰</h2>

</div>

<audio id="birthdayMusic" loop>
<source src="birthday.mp3" type="audio/mpeg">
</audio>

<audio id="secretMusic" loop>
<source src="unvizhigalil.mp3" type="audio/mpeg">
</audio>

<script>

function createHeart(){
const heart=document.createElement("div");
heart.className="heart";
heart.innerHTML="❤️";
heart.style.left=Math.random()*100+"vw";
heart.style.animationDuration=(Math.random()*5+5)+"s";
document.body.appendChild(heart);

setTimeout(()=>{
heart.remove();
},10000);
}
setInterval(createHeart,500);

const targetDate=new Date("June 26, 2026 00:00:00").getTime();

setInterval(()=>{

const now=new Date().getTime();

const distance=targetDate-now;

const days=Math.floor(distance/(1000*60*60*24));

const hours=Math.floor((distance%(1000*60*60*24))/(1000*60*60));

const minutes=Math.floor((distance%(1000*60*60))/(1000*60));

const seconds=Math.floor((distance%(1000*60))/1000);

document.getElementById("countdown").innerHTML=
days+"d "+hours+"h "+minutes+"m "+seconds+"s";

if(distance<0){
document.getElementById("countdownPage").style.display="none";
document.getElementById("unlockPage").style.display="flex";
}

},1000);

function openBirthday(){
document.getElementById("unlockPage").style.display="none";
document.getElementById("birthdayPage").style.display="block";
document.getElementById("birthdayMusic").play();
startConfetti();
}

function showSunset(){
document.getElementById("birthdayPage").style.display="none";
document.getElementById("sunsetPage").style.display="block";

setTimeout(()=>{
document.querySelector(".secretBtn").style.display="inline-block";
},12000);
}

function openSecret(){

document.getElementById("birthdayMusic").pause();

document.getElementById("secretMusic").play();

document.getElementById("sunsetPage").style.display="none";

document.getElementById("secretPage").style.display="block";

typeWriter();
petals();
}

function showEnding(){

document.getElementById("secretPage").style.display="none";

document.getElementById("endingPage").style.display="flex";
}

function startConfetti(){

setInterval(()=>{

const c=document.createElement("div");

c.className="confetti";

const arr=["🎉","🎈","✨","🎂","⭐"];

c.innerHTML=arr[Math.floor(Math.random()*arr.length)];

c.style.left=Math.random()*100+"vw";

document.body.appendChild(c);

setTimeout(()=>{
c.remove();
},8000);

},400);
}

function petals(){

setInterval(()=>{

const p=document.createElement("div");

p.innerHTML="🌸";

p.style.position="fixed";

p.style.left=Math.random()*100+"vw";

p.style.top="-20px";

p.style.fontSize="24px";

p.style.animation="petalFall 8s linear";

document.body.appendChild(p);

setTimeout(()=>{
p.remove();
},8000);

},500);
}

const text=`Unna enakku romba pudikkum da 😘

Unna epdi ellam paathukkanum nu,
unna santhoshama vechukkanum nu
neraya aasai irukku.

Idha romba naala sollanum nu yosichirukken.

Aana nee enna andha maari paakala nu enakku theriyum.

Aana innikku sollala na appuram eppo solla poren nu theriyala.

Adhan solren.

Unna pudicha alavukku idhu varaikkum yaarayum pudichadhu illa ☺️

Yen nu enakkum theriyala.

Aana onnu mattum theriyum —

❤️ Unna Romba Pudikkum ❤️`;

function typeWriter(){

let i=0;

const speed=50;

function typing(){

if(i<text.length){

document.getElementById("typewriter").innerHTML+=text.charAt(i);

i++;

setTimeout(typing,speed);

}
}

typing();
}

</script>

</body>
</html>